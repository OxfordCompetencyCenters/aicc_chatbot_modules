# Copy this file to `.env` and fill in your key. Never commit `.env`.
#
# OpenAI API key (required for every module).
# Oxford API access: https://oerc.ox.ac.uk/ai-centre/generative-ai-tools/api-access
OPENAI_API_KEY=sk-replace-me

# Optional: override the default chat model used in examples.
# OPENAI_MODEL=gpt-4o-mini

# Optional: on-disk location for ChromaDB collections (Module 2+).
# CHROMA_DB_PATH=./chroma_store
